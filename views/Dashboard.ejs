<%- include("partials/header") %>

<section class="bg-slate-950 min-h-screen px-6 py-10">

  <div class="max-w-7xl mx-auto">

    <!-- Welcome -->
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between mb-10 gap-6">
      <div>
        <h1 class="text-3xl font-semibold text-white">
          Welcome back, <span class="text-indigo-500">Rohan</span> 👋
        </h1>
        <p class="text-slate-400 mt-2">
          Here’s what’s happening in your workspace today.
        </p>
      </div>

      <a href="/Rooms"
         class="bg-indigo-600 hover:bg-indigo-500 
                text-white px-6 py-3 rounded-xl 
                font-medium transition shadow-md shadow-indigo-600/20">
        + Create Room
      </a>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">

      <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 hover:border-indigo-500/40 transition">
        <p class="text-slate-400 text-sm">Total Rooms</p>
        <h2 class="text-2xl font-semibold text-white mt-2">12</h2>
      </div>

      <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 hover:border-indigo-500/40 transition">
        <p class="text-slate-400 text-sm">Active Users</p>
        <h2 class="text-2xl font-semibold text-white mt-2">38</h2>
      </div>

      <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 hover:border-indigo-500/40 transition">
        <p class="text-slate-400 text-sm">Messages Today</p>
        <h2 class="text-2xl font-semibold text-white mt-2">245</h2>
      </div>

      <div class="bg-slate-900 border border-slate-800 rounded-xl p-6 hover:border-indigo-500/40 transition">
        <p class="text-slate-400 text-sm">Online Now</p>
        <h2 class="text-2xl font-semibold text-green-400 mt-2">9</h2>
      </div>

    </div>

    <!-- Main Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

      <!-- Recent Rooms -->
      <div class="lg:col-span-2 bg-slate-900 border border-slate-800 rounded-2xl p-8">

        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xl font-semibold text-white">Recent Rooms</h2>
          <a href="/rooms" class="text-indigo-400 hover:text-indigo-300 text-sm transition">
            View All
          </a>
        </div>

        <div class="space-y-4">

          <div class="flex items-center justify-between bg-slate-800/60 px-5 py-4 rounded-xl hover:bg-slate-800 transition">
            <div>
              <h3 class="text-white font-medium">Development Team</h3>
              <p class="text-slate-400 text-sm">12 members • Active</p>
            </div>
            <a href="/room/1"
               class="bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-2 rounded-lg text-sm transition">
              Join
            </a>
          </div>

          <div class="flex items-center justify-between bg-slate-800/60 px-5 py-4 rounded-xl hover:bg-slate-800 transition">
            <div>
              <h3 class="text-white font-medium">Project Alpha</h3>
              <p class="text-slate-400 text-sm">8 members • Active</p>
            </div>
            <a href="/room/2"
               class="bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-2 rounded-lg text-sm transition">
              Join
            </a>
          </div>

        </div>

      </div>

      <!-- Activity Timeline -->
      <div class="bg-slate-900 border border-slate-800 rounded-2xl p-8">

        <h2 class="text-xl font-semibold text-white mb-6">Recent Activity</h2>

        <div class="space-y-5 text-sm">

          <div class="flex items-start gap-3">
            <span class="w-2 h-2 mt-2 bg-green-500 rounded-full"></span>
            <p class="text-slate-300">
              You joined <span class="text-white">Development Team</span>
            </p>
          </div>

          <div class="flex items-start gap-3">
            <span class="w-2 h-2 mt-2 bg-indigo-500 rounded-full"></span>
            <p class="text-slate-300">
              New room <span class="text-white">Project Alpha</span> created
            </p>
          </div>

          <div class="flex items-start gap-3">
            <span class="w-2 h-2 mt-2 bg-yellow-500 rounded-full"></span>
            <p class="text-slate-300">
              25 new messages received today
            </p>
          </div>

        </div>

      </div>

    </div>

  </div>

</section>

<%- include("partials/footer") %>