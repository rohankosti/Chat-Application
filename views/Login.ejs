<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Convoxa</title>

  <!-- Google Font (Professional SaaS Look) -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

  <!-- Tailwind CDN -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Tailwind Custom Config -->
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'sans-serif'],
          },
          colors: {
            primary: '#4f46e5',
          }
        }
      }
    }
  </script>

  <style>
    body {
      font-family: 'Inter', sans-serif;
    }
  </style>

</head>

<body>

  <section class="min-h-screen flex items-center justify-center bg-slate-950 px-6">

    <div class="w-full max-w-md bg-slate-900 border border-slate-800 rounded-2xl p-8 shadow-xl">

      <!-- Brand -->
      <div class="flex items-center justify-center gap-3 mb-8">

        <div class="w-10 h-10 rounded-xl bg-indigo-600 
                  flex items-center justify-center 
                  shadow-lg shadow-indigo-600/30">
          <span class="text-white font-semibold tracking-widest">CX</span>
        </div>

        <h1 class="text-2xl font-semibold text-white tracking-tight">
          Convo<span class="text-indigo-500">xa</span>
        </h1>

      </div>

      <!-- Heading -->
      <h2 class="text-xl font-semibold text-white text-center mb-2">
        Welcome Back
      </h2>
      <p class="text-sm text-slate-400 text-center mb-6">
        Sign in to continue to your dashboard
      </p>

      <!-- Form -->
      <form id="loginform" class="space-y-5">

        <!-- Email -->
        <div>
          <label class="block text-sm text-slate-400 mb-2">Email</label>
          <input type="email" name="email" required class="w-full px-4 py-3 bg-slate-800 border border-slate-700 
                 rounded-lg text-white placeholder-slate-500 
                 focus:outline-none focus:ring-2 focus:ring-indigo-500 
                 transition" placeholder="Enter your email" id="email">
        </div>

        <!-- Password -->
        <div>
          <label class="block text-sm text-slate-400 mb-2">Password</label>
          <input type="password" name="password" required class="w-full px-4 py-3 bg-slate-800 border border-slate-700 
                 rounded-lg text-white placeholder-slate-500 
                 focus:outline-none focus:ring-2 focus:ring-indigo-500 
                 transition" placeholder="Enter your password" id="password">
        </div>


        <!-- Button -->
        <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-500 
               text-white font-medium py-3 rounded-lg 
               transition duration-200 shadow-md shadow-indigo-600/20">
          Login
        </button>

      </form>

      <!-- Footer Link -->
      <p class="text-sm text-slate-400 text-center mt-6">
        Don't have an account?
        <a href="/signup" class="text-indigo-400 hover:text-indigo-300 transition">
          Sign up
        </a>
      </p>
      <div id="err" class="mt-2 text-sm text-center w-full text-red-400 min-h-[20px]"></div>

    </div>
  </section>

  <script>
    const loginform = document.getElementById("loginform");
    const eroor = document.getElementById("err");
    loginform.addEventListener("submit", async (e) => {
      try {

        e.preventDefault()
        const email = document.getElementById("email").value;
        const password = document.getElementById("password").value;
        const obj = {
          email: email,
          password: password
        };

        const res = await fetch("http://localhost:3000/logindata", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify(obj)
        })

        const data = await res.json();
        console.log(data);

        localStorage.setItem("User", JSON.stringify(data.User)); //Beckend send User object

        if (res.ok) {
          eroor.innerHTML = `
        <div class="bg-green-500/10 border border-green-500 
        text-green-400 px-4 py-2 rounded-lg">
        ${data.msg}
        </div>`;
          setTimeout(() => {
            window.location.href = "/Dashboard"
            eroor.innerHTML = ""
          }, 2000);
        }

        else {
          eroor.innerHTML = `
    <div class="bg-red-500/10 border border-red-500 
    text-red-400 px-4 py-2 rounded-lg">
    ${data.msg}
    </div>`;
          loginform.reset()

        }
      } catch (error) {
        console.error(eroor);
        loginform.reset()

      }


    })
  </script>

  <%- include("partials/footer") %>