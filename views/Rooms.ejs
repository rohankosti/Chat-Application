<div class="row">
  <div class="col-md-8">
    <div class="card shadow">
      <div class="card-header bg-dark text-white">
        Room: <%= room %>
      </div>

      <div class="card-body chat-box" id="messages"></div>

      <div class="card-footer">
        <form id="chatForm">
          <div class="input-group">
            <input type="text" id="msgInput" class="form-control" placeholder="Type message...">
            <button class="btn btn-dark">Send</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card shadow">
      <div class="card-header bg-secondary text-white">
        Online Users
      </div>
      <ul class="list-group list-group-flush" id="onlineUsers"></ul>
    </div>
  </div>
</div>

<script>
  window.currentUser = "<%= user.username %>";
  window.currentRoom = "<%= room %>";
</script>

<script src="/js/socket.js"></script>